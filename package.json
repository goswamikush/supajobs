{
  "name": "supajobs",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "bin": {
    "supajobs": "./src/cli/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "infra:init": "terraform -chdir=terraform init",
    "infra:plan": "terraform -chdir=terraform plan",
    "infra:apply": "terraform -chdir=terraform apply",
    "infra:destroy": "terraform -chdir=terraform destroy",
    "deploy:lambda": "tsx scripts/deploy-lambda.ts",
    "deploy:base": "tsx scripts/deploy-base.ts",
    "setup": "npm run infra:apply && npm run deploy:base && npm run deploy:lambda && npm link",
    "kill": "aws lambda put-function-concurrency --function-name supajobs-trigger --reserved-concurrent-executions 0 --region us-east-1 && aws ecs list-tasks --cluster supajobs --region us-east-1 --query 'taskArns[]' --output text | xargs -I {} aws ecs stop-task --cluster supajobs --task {} --region us-east-1",
    "resume": "aws lambda delete-function-concurrency --function-name supajobs-trigger --region us-east-1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^26.1.0",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-codebuild": "^3.1078.0",
    "@aws-sdk/client-dynamodb": "^3.1078.0",
    "@aws-sdk/client-ecr": "^3.1078.0",
    "@aws-sdk/client-ecs": "^3.1078.0",
    "@aws-sdk/client-s3": "^3.1078.0",
    "@aws-sdk/lib-dynamodb": "^3.1078.0",
    "@clack/prompts": "^1.6.0",
    "zod": "^4.4.3"
  }
}
